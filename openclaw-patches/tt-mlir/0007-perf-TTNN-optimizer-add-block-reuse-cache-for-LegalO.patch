From dca15a188fa026392bb86fe89511be7e63d4c4c4 Mon Sep 17 00:00:00 2001
From: nvukobratTT <nvukobratTT@users.noreply.github.com>
Date: Thu, 9 Apr 2026 00:33:25 +0000
Subject: [PATCH 7/8] perf(TTNN optimizer): add block-reuse cache for
 LegalOpLayoutAnalysis

Transformer models repeat identical attention blocks N times (e.g. 48 for
Mochi 10B). Each repeated block has the same op types and tensor shapes, so
LegalOpLayoutAnalysis + LegalOpConfigAnalysis produce identical results.

This patch adds a fingerprint cache (op_type x operand shapes x dtypes x
result shapes -> vector<OpConfig>) in the optimizer walk. On a cache hit,
the analysis is skipped entirely and configs are copied from block 1. On a
cache miss, the full analysis runs and populates the cache.

Expected impact:
- Cache-hit rate: ~90-95% for standard transformer architectures
- Blocks 2..48 skip device OpModel queries entirely
- Additional 15-30% compile time reduction on top of TTNNOpsModelCache
  and maxLegalLayoutsElementwise cap

Cache stats are logged at LOG_DEBUG level:
  TTNNOptimizer legalConfigCache: N hits / M misses

Upstream tracking: https://github.com/nvukobratTT/tt-xla/issues/2
---
 .../Transforms/OptimizerPasses/Optimizer.cpp  | 99 +++++++++++++++----
 1 file changed, 80 insertions(+), 19 deletions(-)

diff --git a/lib/Dialect/TTNN/Transforms/OptimizerPasses/Optimizer.cpp b/lib/Dialect/TTNN/Transforms/OptimizerPasses/Optimizer.cpp
index 3645f875f..7d20ba57d 100644
--- a/lib/Dialect/TTNN/Transforms/OptimizerPasses/Optimizer.cpp
+++ b/lib/Dialect/TTNN/Transforms/OptimizerPasses/Optimizer.cpp
@@ -47,6 +47,39 @@
 #include "llvm/Support/Error.h"
 #include "llvm/Support/ErrorHandling.h"
 
+
+// Compute a structural fingerprint for an op to detect structurally-identical
+// ops across repeated transformer blocks. Includes op type + operand shapes +
+// element types + result shapes so that identical blocks produce cache hits
+// while different-shape ops (e.g. different sequence lengths) produce misses.
+static size_t computeOpLayoutFingerprint(mlir::Operation *op) {
+  size_t h = 0;
+  llvm::hash_combine(h, op->getName().getAsOpaquePointer());
+  for (mlir::Value operand : op->getOperands()) {
+    auto tensorType =
+        mlir::dyn_cast<mlir::RankedTensorType>(operand.getType());
+    if (!tensorType) {
+      continue;
+    }
+    for (int64_t dim : tensorType.getShape()) {
+      llvm::hash_combine(h, dim);
+    }
+    llvm::hash_combine(h, tensorType.getElementType());
+  }
+  for (mlir::OpResult result : op->getResults()) {
+    auto tensorType =
+        mlir::dyn_cast<mlir::RankedTensorType>(result.getType());
+    if (!tensorType) {
+      continue;
+    }
+    for (int64_t dim : tensorType.getShape()) {
+      llvm::hash_combine(h, dim);
+    }
+    llvm::hash_combine(h, tensorType.getElementType());
+  }
+  return h;
+}
+
 namespace mlir::tt::ttnn {
 
 TTNNOptimizerOptions::TTNNOptimizerOptions(
@@ -357,6 +390,15 @@ public:
         ttcore::lookupDevice(moduleOp).getWorkerGrid();
 
     llvm::DenseMap<Operation *, std::vector<OpConfig>> legalConfigs;
+
+    // Block-reuse cache: fingerprint -> legal op configs.
+    // Transformer models repeat identical attention blocks N times. After block 1,
+    // blocks 2..N skip LegalOpLayoutAnalysis + LegalOpConfigAnalysis entirely,
+    // reusing the computed configs. Expected cache-hit rate: ~90-95% for standard
+    // transformer architectures (Mochi 10B: 48 attention blocks).
+    llvm::DenseMap<size_t, std::vector<OpConfig>> legalConfigCache;
+    size_t legalConfigCacheHits = 0;
+    size_t legalConfigCacheMisses = 0;
     // Map to store only L1 Interleaved legal configs for
     // L1InterleavedFallbackAnalysis.
     llvm::DenseMap<Operation *, std::vector<OpConfig>>
@@ -408,25 +450,41 @@ public:
 
         assert(hasLayoutsForTensorType && "No layouts found for tensor type");
 
-        // Run legal layout analysis to select the best layouts.
-        LegalOpLayoutAnalysis legalOpLayoutAnalysis =
-            getChildAnalysis<LegalOpLayoutAnalysis>(op);
-        // Elementwise ops (unary/binary) don't benefit from exploring large
-        // sharded layout spaces. Cap their search to save OpModel queries.
-        int64_t effectiveMaxLegalLayouts =
-            (mlir::isa<ElementwiseUnary>(op) ||
-             mlir::isa<ElementwiseBinary>(op))
-                ? maxLegalLayoutsElementwise
-                : maxLegalLayouts;
-        legalOpLayoutAnalysis.init(LegalOpLayoutAnalysisInput(
-            &tensorLayouts->getSecond(), effectiveMaxLegalLayouts,
-            &overrideOutputLayout, rowMajorEnabled));
-
-        LegalOpConfigAnalysis legalOpConfigAnalysis =
-            getChildAnalysis<LegalOpConfigAnalysis>(op);
-        legalOpConfigAnalysis.init(LegalOpConfigAnalysisInput(
-            legalOpLayoutAnalysis.getResult(), &overrideConv2dConfig));
-        legalConfigs[op] = legalOpConfigAnalysis.getResult();
+        // Block-reuse cache: check if we have seen a structurally-identical op.
+        size_t opFP = computeOpLayoutFingerprint(op);
+        if (auto cacheIt = legalConfigCache.find(opFP);
+            cacheIt != legalConfigCache.end()) {
+          // Cache hit: reuse legal configs from a structurally-identical op
+          // in a prior block. Skips device OpModel queries entirely.
+          legalConfigs[op] = cacheIt->second;
+          ++legalConfigCacheHits;
+        } else {
+          // Cache miss: run full legal layout + config analysis.
+          ++legalConfigCacheMisses;
+
+          // Run legal layout analysis to select the best layouts.
+          LegalOpLayoutAnalysis legalOpLayoutAnalysis =
+              getChildAnalysis<LegalOpLayoutAnalysis>(op);
+          // Elementwise ops (unary/binary) don't benefit from exploring large
+          // sharded layout spaces. Cap their search to save OpModel queries.
+          int64_t effectiveMaxLegalLayouts =
+              (mlir::isa<ElementwiseUnary>(op) ||
+               mlir::isa<ElementwiseBinary>(op))
+                  ? maxLegalLayoutsElementwise
+                  : maxLegalLayouts;
+          legalOpLayoutAnalysis.init(LegalOpLayoutAnalysisInput(
+              &tensorLayouts->getSecond(), effectiveMaxLegalLayouts,
+              &overrideOutputLayout, rowMajorEnabled));
+
+          LegalOpConfigAnalysis legalOpConfigAnalysis =
+              getChildAnalysis<LegalOpConfigAnalysis>(op);
+          legalOpConfigAnalysis.init(LegalOpConfigAnalysisInput(
+              legalOpLayoutAnalysis.getResult(), &overrideConv2dConfig));
+          legalConfigs[op] = legalOpConfigAnalysis.getResult();
+
+          // Populate the cache so subsequent identical ops get a hit.
+          legalConfigCache[opFP] = legalConfigs[op];
+        }
 
         // Save only L1 Interleaved legal configs in a separate map for
         // L1InterleavedFallbackAnalysis later
@@ -447,6 +505,9 @@ public:
       });
     });
 
+    DLOG_F(LOG_DEBUG, "TTNNOptimizer legalConfigCache: %zu hits / %zu misses",
+           legalConfigCacheHits, legalConfigCacheMisses);
+
     llvm::DenseMap<func::FuncOp, llvm::SmallVector<Operation *>> opSchedule;
     llvm::DenseMap<Edge, MemReconfigEntry> memReconfigEntryMap;
     std::vector<Operation *> spillToDramOps;
