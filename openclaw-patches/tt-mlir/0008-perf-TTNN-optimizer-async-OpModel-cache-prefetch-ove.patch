+++ b/lib/Dialect/TTNN/Transforms/OptimizerPasses/Optimizer.cpp
@@ -428,12 +428,28 @@ public:
 
     tracePossibleLayouts(tensorTypePossibleLayouts);
 
+// Async OpModel prefetch: collect all forward-function ops first, then
+    // process each func sequentially while a background thread pre-warms the
+    // opConstraintsCache for the next func. The prefetch uses gDeviceQueryMutex
+    // (in TTNNOpModel.cpp) to serialize device queries from the background
+    // thread; the main thread's LegalOpLayoutAnalysis calls are serialized by
+    // the single-threaded walk. This overlaps cache-fill for func[N+1] with
+    // DFSharding (CPU-only) for func[N] in multi-function modules, and for
+    // single-function models the background thread completes before the main
+    // thread reaches the same ops (no-op in the common case).
+    std::future<void> prefetchFuture;
+
     moduleOp->walk([&](func::FuncOp func) {
       // Apply analysis only on forward functions.
       if (!ttmlir::utils::isForwardDeviceFunc(func)) {
         return;
       }
 
+      // Wait for any in-flight prefetch before accessing the cache.
+      if (prefetchFuture.valid()) {
+        prefetchFuture.wait();
+      }
+
       func->walk([&](Operation *op) {
         if (!LegalOpLayoutAnalysis::isValidAnalysisTarget(op)) {
           return;
diff --git a/lib/OpModel/TTNN/TTNNOpModel.cpp b/lib/OpModel/TTNN/TTNNOpModel.cpp
index 1e96a0630..1e13f1ffb 100644
--- a/lib/OpModel/TTNN/TTNNOpModel.cpp
+++ b/lib/OpModel/TTNN/TTNNOpModel.cpp
@@ -26,6 +26,8 @@
 #include <array>
 #include <cstddef>
 #include <cstdint>
+#include <future>
+#include <mutex>
 #include <optional>
 #include <stdexcept>
 #include <type_traits>
@@ -55,6 +57,18 @@ struct ProgramCacheState {
   }
 };
 
+// Serializes executeConstraintQuery calls from background prefetch threads.
+// The TT device context is not thread-safe; concurrent queries from separate
+// threads must be serialized with this mutex. The main optimizer thread owns
+// the single-threaded path; background prefetch threads acquire this lock.
+static std::mutex gDeviceQueryMutex;
+
+// Spec describing one op to pre-warm in the OpModel constraints cache.
+struct OpPrefetchSpec {
+  mlir::Operation *op;
+  llvm::hash_code hash; // pre-computed argument hash for cache keying
+};
