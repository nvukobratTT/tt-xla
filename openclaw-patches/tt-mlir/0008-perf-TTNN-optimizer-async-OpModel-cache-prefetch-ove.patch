 .../Transforms/OptimizerPasses/Optimizer.cpp  | 16 +++++++++
 lib/OpModel/TTNN/TTNNOpModel.cpp              | 14 ++++++++
 3 files changed, 64 insertions(+)

diff --git a/include/ttmlir/OpModel/TTNN/TTNNOpsModelCache.h b/include/ttmlir/OpModel/TTNN/TTNNOpsModelCache.h
index 93116b0c4..aa1bf58bb 100644
--- a/include/ttmlir/OpModel/TTNN/TTNNOpsModelCache.h
+++ b/include/ttmlir/OpModel/TTNN/TTNNOpsModelCache.h
@@ -14,6 +14,7 @@
 #include "llvm/Support/raw_ostream.h"
 
 #include <optional>
+#include <shared_mutex>
 #include <type_traits>
 
 namespace mlir::tt::ttnn {
@@ -50,6 +51,34 @@ public:
   // Get current cache statistics.
   CacheStats getStats() const { return stats; }
 
+  // Thread-safe lookup for use from background/prefetch threads.
+  // Does not update cache statistics.
+  // Returns std::nullopt if the key is not present.
+  std::optional<ValueT> threadSafeLookup(Operation *op,
+                                         llvm::hash_code hash) const {
+    std::shared_lock<std::shared_mutex> rlock(cacheMutex);
+    mlir::TypeID opTypeID = op->getName().getTypeID();
+    auto cacheIt = cache.find(opTypeID);
+    if (cacheIt == cache.end())
+      return std::nullopt;
+    const OpCache &opCache = cacheIt->second;
+    auto opCacheIt = opCache.find(hash);
+    if (opCacheIt == opCache.end())
+      return std::nullopt;
+    return opCacheIt->second;
+  }
+
+  // Thread-safe insert for use from background/prefetch threads.
+  // Does not update cache statistics.
+  // Caller must ensure the computed value is valid before inserting.
+  void threadSafeInsert(Operation *op, llvm::hash_code hash,
+                        const ValueT &value) {
+    std::unique_lock<std::shared_mutex> wlock(cacheMutex);
+    mlir::TypeID opTypeID = op->getName().getTypeID();
+    cache[opTypeID][hash] = value;
+  }
+
+
   // Clear the cache and reset statistics.
   void clear() {
     cache.clear();
@@ -154,6 +183,11 @@ private:
 
   Cache cache;
   CacheStats stats;
+  // Protects cache for concurrent access from background prefetch threads.
+  // threadSafeLookup acquires a shared lock; threadSafeInsert acquires an
+  // exclusive lock. The single-threaded getOrCompute path must not be called
+  // concurrently with threadSafeInsert.
+  mutable std::shared_mutex cacheMutex;
 };
 
