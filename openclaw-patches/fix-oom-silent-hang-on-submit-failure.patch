From: Autonomous Task Worker <claw@openclaw>
Date: Wed, 8 Apr 2026
Subject: [PATCH] fix: don't hang on device OOM in flatbuffer execute()

When tt::runtime::submit throws (e.g. device DRAM OOM), invoke_noexcept
catches the exception and returns std::nullopt. The previous code then
called m_client_instance->closeMeshDevice(), which hangs indefinitely
because the SPMD ethernet cores involved in the all-reduce are stuck
waiting for data that never arrives.

Fix: remove the closeMeshDevice() call on submit failure. Instead, log
a clear diagnostic message and return kInternal immediately so the
error propagates to the Python caller (JAX/XLA) as an exception. The
device remains in a bad state — the user still needs tt-smi -r and a
process restart to recover — but the Python process now terminates
cleanly instead of hanging forever.

Also add a m_has_fatal_error flag to ClientInstance so that subsequent
execute() calls on the same instance fail fast rather than re-submitting
to a broken device.

Fixes: https://github.com/nvukobratTT/tt-xla/issues/11

---
 pjrt_implementation/inc/api/client_instance.h                | 14 ++++++
 .../src/api/flatbuffer_loaded_executable_instance.cc          | 27 +++++++++--
 2 files changed, 38 insertions(+), 3 deletions(-)

diff --git a/pjrt_implementation/inc/api/client_instance.h b/pjrt_implementation/inc/api/client_instance.h
index xxxxxxx..xxxxxxx 100644
--- a/pjrt_implementation/inc/api/client_instance.h
+++ b/pjrt_implementation/inc/api/client_instance.h
@@ -143,6 +143,18 @@ class ClientInstance {
   const std::optional<tt::runtime::Device> &getConstParentMesh() const {
     return m_parent_mesh;
   }
+
+  // Returns true if the device has encountered a fatal, unrecoverable error
+  // (e.g. DRAM OOM during execution). Subsequent execute() calls will fail
+  // immediately without attempting to submit to the broken device.
+  bool hasFatalDeviceError() const { return m_has_fatal_device_error; }
+
+  // Marks the device as having a fatal error. Called by execute() when
+  // tt::runtime::submit fails. Once set, cannot be cleared — the process
+  // must be restarted and tt-smi -r run to recover the device.
+  void setFatalDeviceError() { m_has_fatal_device_error = true; }
+
   void closeMeshDevice();

 private:
@@ -222,6 +234,8 @@ class ClientInstance {
   std::optional<tt::runtime::Device> m_parent_mesh;
   std::optional<tt::runtime::MeshFabricConfig> m_fabric_config;
   std::optional<tt::runtime::Device> m_optimizer_submesh;
+  // Set to true when the device enters an unrecoverable error state.
+  bool m_has_fatal_device_error = false;
 };
 
 } // namespace tt::pjrt

diff --git a/pjrt_implementation/src/api/flatbuffer_loaded_executable_instance.cc b/pjrt_implementation/src/api/flatbuffer_loaded_executable_instance.cc
index xxxxxxx..xxxxxxx 100644
--- a/pjrt_implementation/src/api/flatbuffer_loaded_executable_instance.cc
+++ b/pjrt_implementation/src/api/flatbuffer_loaded_executable_instance.cc
@@ -191,6 +191,16 @@ tt_pjrt_status FlatbufferLoadedExecutableInstance::execute(
   ZoneScoped;
   DLOG_F(LOG_DEBUG, "FlatbufferLoadedExecutableInstance::Execute");
   LOG_BRINGUP_STAGE("RUNTIME_EXECUTION_START");
+
+  // Fail fast if a previous execution left the device in a fatal error state.
+  // The device cannot be recovered within this process; the user must run
+  // `tt-smi -r <device_ids>` and restart the process.
+  if (m_client_instance->hasFatalDeviceError()) {
+    LOG_F(ERROR,
+          "Device is in an unrecoverable error state from a previous "
+          "execution failure. Run 'tt-smi -r <device_ids>' and restart "
+          "the process to recover.");
+    return tt_pjrt_status::kInternal;
+  }
 
   if (args->num_devices != m_executable_image->getNumDevicesToUtilize()) {
     LOG_F(ERROR, "Device count mismatch: %zu vs %zu", args->num_devices,
@@ -237,9 +247,20 @@ tt_pjrt_status FlatbufferLoadedExecutableInstance::execute(
   auto r = utils::invoke_noexcept(tt::runtime::submit, *runtime_device,
                                   executable_image->getFlatbufferBinary(),
                                   program_index, input_tensors);
-
   if (!r) {
-    m_client_instance->closeMeshDevice();
-    return tt_pjrt_status::kInternal;
+    // Do NOT call closeMeshDevice() here.
+    //
+    // When tt::runtime::submit throws (e.g. device DRAM OOM: "Not enough
+    // space to allocate X B DRAM buffer across N banks"), the exception
+    // propagates through the PJRT stack. For SPMD multi-chip execution, the
+    // ethernet cores involved in the all-reduce are stuck waiting for data
+    // that never arrives. Calling closeMeshDevice() at this point will block
+    // indefinitely waiting for those stuck cores to drain.
+    //
+    // Instead: mark the device as fatally broken, log a clear message, and
+    // return kInternal immediately so JAX/XLA raises a Python exception.
+    m_client_instance->setFatalDeviceError();
+    LOG_F(ERROR,
+          "tt::runtime::submit failed — possible causes: device DRAM OOM "
+          "(increase sequence length limit or reduce batch size), hardware "
+          "fault, or compiler/runtime mismatch. Device is now in an "
+          "unrecoverable state. Run 'tt-smi -r <device_ids>' and restart "
+          "the process to recover. Check loguru output for the original "
+          "exception message.");
+    return tt_pjrt_status::kInternal;
   }
