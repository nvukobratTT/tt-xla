+def TTNNCheckDRAMBudget : Pass<"ttnn-check-dram-budget", "::mlir::ModuleOp"> {
+  let summary = "Check estimated peak DRAM usage against per-chip budget.";
+  let description = [{
+    After deallocation ops are inserted, this pass simulates tensor
+    lifetimes to estimate peak DRAM usage per chip. If the estimated peak
+    exceeds the device's usable DRAM budget, the pass emits a compile-time
+    error to prevent a silent runtime hang (see GH #11).
+
+    The estimation works by walking all ops in execution order, adding the
+    DRAM bytes of each result tensor to a running total, and subtracting
+    bytes when a DeallocateOp frees that tensor. Function arguments
+    (model weights) are treated as permanently live.
+
+    For TP-sharded (SPMD) models, tensor shapes in the IR already reflect
+    per-chip sizes after SPMD sharding, so the check is against the
+    single-chip DRAM budget.
+
+    A warning is also emitted at 90% utilisation to provide an early signal
+    before the budget is exceeded.
+  }];
+}
